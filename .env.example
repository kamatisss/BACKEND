# Copy this file to .env and fill in your values.
# The .env file is git-ignored — never commit real secrets.

# ─── Django ──────────────────────────────────────────────────────────────────
# Generate a new key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-CHANGE-ME

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
# Get from Stripe Dashboard > Developers > Webhooks > your endpoint
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ─── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Gemini ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=gemeni_api_here
